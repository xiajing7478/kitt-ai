# 复制此文件为 .env 后再填入真实值即可运行项目。
# .env 已加入 .gitignore，不会被提交到代码仓库。

# 通义千问 API Key，用于 /api/chat 聊天接口
DASHSCOPE_API_KEY=your-dashscope-api-key

# 服务监听端口
PORT=5002

# PostgreSQL 连接配置
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=kitt
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# JWT 签名密钥，务必替换为足够长的随机字符串
# 生成命令示例：node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# JWT 有效期，支持 60s、15m、2h、7d 等写法
JWT_EXPIRES_IN=2h
